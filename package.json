{
  "name": "dreamfest",
  "type": "module",
  "version": "0.1.0",
  "description": "NZ's premier culture festival",
  "main": "index.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "run-p dev:client dev:server",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "run-s build:client build:server",
    "build:client": "vite build",
    "build:server": "esbuild --packages=external --platform=node --format=esm --outfile=dist/server.js --bundle server/index.ts",
    "test": "vitest",
    "knex": "knex --knexfile ./server/db/knexfile.js",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx .",
    "format": "prettier -w '**/*.{js,jsx,ts,tsx}'",
    "render:build": "npm install && npm run build && npm prune --omit=dev && NODE_ENV='production' npm run knex migrate:latest",
    "render:start": "node dist/server.js"
  },
  "author": "Dev Academy Aotearoa",
  "license": "ISC",
  "keywords": [
    "db",
    "database",
    "backend"
  ],
  "homepage": "https://github.com/dev-academy-challenges/dreamfest#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dev-academy-challenges/dreamfest.git"
  },
  "eslintConfig": {
    "extends": "@devacademy"
  },
  "dependencies": {
    "express": "^4.22.1",
    "knex": "^2.5.1",
    "pg": "^8.20.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@devacademy/eslint-config": "^1.10.2",
    "@tanstack/react-query": "^5.22.2",
    "@testing-library/dom": "^8.17.1",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/express": "^4.17.21",
    "@types/superagent": "^8.1.1",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^5.1.2",
    "esbuild": "^0.27.2",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-promise": "^7.2.1",
    "jsdom": "^22.1.0",
    "nock": "^14.0.5",
    "nodemon": "^3.1.11",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.2.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "^7.13.0",
    "superagent": "^10.2.2",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "vite": "^7.3.1",
    "vitest": "^3.0.5"
  },
  "overrides": {
    "sqlite3": {
      "node-gyp": "12.2.0",
      "tar": "7.5.7"
    }
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  }
}
